# ── LLM Provider (required) ────────────────────────────────────────
# Crow uses OpenAI-compatible APIs. Pick ONE:
#
# Option A: OpenRouter (free models available)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Option B: OpenCode.ai
# OPENCODE_GO_API_KEY=sk-your-key-here
# OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
# OPENCODE_GO_MODEL=deepseek-v4-flash

# ── Telegram Bot (optional) ─────────────────────────────────────────
# TELEGRAM_TOKEN=your-bot-token
# TELEGRAM_ALLOWED_IDS=your-telegram-id

# ── Heartbeat Slices (optional) ─────────────────────────────────────
# HEARTBEAT_ENABLE_SLICES=all

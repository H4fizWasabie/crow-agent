# ── LLM Provider (required) ────────────────────────────────────────
# OpenRouter — free models, no credit card needed.
# Get your key: https://openrouter.ai/keys
#
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ── Alternative providers (auto-detected) ───────────────────────────
# Add any {NAME}_API_KEY, {NAME}_BASE_URL, {NAME}_MODEL — Crow picks it up.
# Example for OpenCode.ai:
# OPENCODE_GO_API_KEY=sk-your-key-here
# OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
# OPENCODE_GO_MODEL=deepseek-v4-flash

# ── Telegram Bot (optional) ─────────────────────────────────────────
# TELEGRAM_TOKEN=your-bot-token
# TELEGRAM_ALLOWED_IDS=your-telegram-id
